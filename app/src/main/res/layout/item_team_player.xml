<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/teamPlayerItemContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="4dp"
    android:background="@drawable/bg_white"
    android:elevation="2dp"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:padding="8dp">

    <FrameLayout
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="8dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/playerAvatarImageView"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:scaleType="centerCrop"
            android:src="@drawable/avatar_1"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeColor="@color/color_lavender"
            app:strokeWidth="1dp" />

        <View
            android:id="@+id/playerOnlineStatusView"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:layout_gravity="end|bottom"
            android:background="@drawable/status_online" />
    </FrameLayout>

    <LinearLayout
        android:id="@+id/playerInfoContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/playerNameTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/item_team_player_player_name"
            android:textColor="@color/color_navy_blue"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/playerIdTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/item_team_player_id_ael_29481"
            android:textColor="@color/color_text_hint"
            android:textSize="9sp" />

        <LinearLayout
            android:id="@+id/playerScoreContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/playerScoreIconImageView"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:contentDescription="@string/item_team_player_score_icon"
                android:src="@drawable/ic_score" />

            <TextView
                android:id="@+id/playerScoreTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="3dp"
                android:text="@string/item_team_player__1250"
                android:textColor="@color/color_navy_blue"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <ImageView
        android:id="@+id/playerKickImageView"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_white"
        android:clickable="true"
        android:contentDescription="@string/item_team_player_kick_player"
        android:focusable="true"
        android:padding="8dp"
        android:src="@drawable/ic_close"
        android:visibility="gone"
        app:tint="@color/color_error"
        tools:visibility="visible" />

</LinearLayout>