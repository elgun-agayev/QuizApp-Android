<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/profileRootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    android:clipChildren="false"
    android:clipToPadding="false"
    tools:context=".ui.ProfileFragment">

    <ScrollView
        android:id="@+id/profileScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingBottom="96dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:paddingTop="36dp">

        <LinearLayout
            android:id="@+id/profileContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <LinearLayout
                android:id="@+id/profileHeaderContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="28dp"
                android:layout_marginEnd="20dp"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <FrameLayout
                    android:layout_width="112dp"
                    android:layout_height="112dp"
                    android:layout_gravity="center_horizontal">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/avatarImageView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/profile_avatar"
                        android:scaleType="centerCrop"
                        android:src="@drawable/ic_avatar_placeholder"
                        app:shapeAppearanceOverlay="@style/CircleImage"
                        app:strokeColor="#AE844F"
                        app:strokeWidth="2dp" />

                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:layout_margin="4dp"
                        app:cardBackgroundColor="@color/color_orange_primary"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="2dp">

                        <ImageView
                            android:id="@+id/editAvatarImageView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/profile_edit_avatar"
                            android:padding="7dp"
                            android:src="@drawable/ic_edit"
                            app:tint="@color/color_white" />
                    </com.google.android.material.card.MaterialCardView>

                </FrameLayout>

                <LinearLayout
                    android:id="@+id/profileInfoContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/playerNameTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:gravity="center"
                        android:maxLines="1"
                        android:text="@string/profile_joseph"
                        android:textAlignment="center"
                        android:textColor="@color/color_navy_blue"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        tools:text="Joseph" />

                    <TextView
                        android:id="@+id/playerIdTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:paddingStart="8dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="8dp"
                        android:paddingBottom="4dp"
                        android:text="@string/profile_id_ael_29481"
                        android:textAlignment="center"
                        android:textColor="@color/color_text_hint"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        tools:text="ID: AEL-29481" />

                    <LinearLayout
                        android:id="@+id/scoreContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/scoreIconImageView"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:contentDescription="@string/profile_score_icon"
                            android:src="@drawable/ic_score" />

                        <TextView
                            android:id="@+id/scoreTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:text="@string/profile__12500"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="12500" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/statusCardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/color_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="#E9E9EF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/statusCardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <LinearLayout
                        android:id="@+id/statusHeaderContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="44dp"
                        android:orientation="horizontal"
                        android:paddingStart="4dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:id="@+id/statusArrowImageView"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_arrow_right" />

                        <TextView
                            android:id="@+id/statusTitleTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/profile_status"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/onlineStatusTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_online"
                            android:textColor="@color/color_green"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="Online" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/statusDetailsContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/gameCountRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:minHeight="40dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/gameCountLabelTextView"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/profile_game_count"
                                android:textColor="@color/color_text_hint"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/gameCountValueTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/profile__128"
                                android:textColor="@color/color_navy_blue"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                tools:text="128" />
                        </LinearLayout>

                        <View
                            android:id="@+id/statusDividerView"
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginBottom="8dp"
                            android:background="#EAEAF2" />

                        <LinearLayout
                            android:id="@+id/correctAnswerRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:minHeight="40dp"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/correctAnswerLabelTextView"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/profile_correct_answers"
                                android:textColor="@color/color_text_hint"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/correctAnswerValueTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/profile__924"
                                android:textColor="@color/color_navy_blue"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                tools:text="924" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/friendDetailsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/friendsCardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/color_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="#E9E9EF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/friendsCardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <LinearLayout
                        android:id="@+id/friendsHeaderContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="44dp"
                        android:orientation="horizontal"
                        android:paddingStart="4dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:id="@+id/friendsArrowImageView"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_arrow_right" />

                        <TextView
                            android:id="@+id/friendsTitleTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/profile_friends"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/friendsMoreOptionsImageView"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginStart="8dp"
                            android:contentDescription="@string/profile_more_options"
                            android:src="@drawable/ic_menu_horizontal"
                            android:visibility="gone" />
                    </LinearLayout>

                    <View
                        android:id="@+id/friendsDividerView"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="#EAEAF2"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/noFriendsTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="@string/profile_you_have_no_friends_yet"
                        android:textColor="@color/color_text_hint"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/friendsRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/friendRequestsCardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/color_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="#E9E9EF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/friendRequestsCardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <LinearLayout
                        android:id="@+id/friendRequestsHeaderContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="44dp"
                        android:orientation="horizontal"
                        android:paddingStart="4dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:id="@+id/friendRequestsArrowImageView"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_arrow_right" />

                        <TextView
                            android:id="@+id/friendRequestsTitleTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/profile_friend_requests"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/friendRequestsCountTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile__0"
                            android:textColor="@color/color_orange_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="0" />
                    </LinearLayout>

                    <View
                        android:id="@+id/friendRequestsDividerView"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="#EAEAF2"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/noFriendRequestsTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="@string/profile_no_friend_requests"
                        android:textColor="@color/color_text_hint"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/friendRequestsRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/gameRequestsCardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/color_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="#E9E9EF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/gameRequestsCardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <LinearLayout
                        android:id="@+id/gameRequestsHeaderContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="44dp"
                        android:orientation="horizontal"
                        android:paddingStart="4dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:id="@+id/gameRequestsArrowImageView"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_arrow_right" />

                        <TextView
                            android:id="@+id/gameRequestsTitleTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/profile_game_requests"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/gameRequestsCountTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/profile__0"
                            android:textColor="@color/color_orange_primary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            tools:text="2" />
                    </LinearLayout>

                    <View
                        android:id="@+id/gameRequestsDividerView"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="#EAEAF2"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/noGameRequestsTextView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:padding="12dp"
                        android:text="@string/profile_no_game_requests"
                        android:textColor="@color/color_text_hint"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/gameRequestsRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never"
                        android:visibility="gone" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/menuCardView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="16dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/color_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="3dp"
                app:strokeColor="#E9E9EF"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:id="@+id/menuCardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="10dp">

                    <LinearLayout
                        android:id="@+id/menuHeaderContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:minHeight="44dp"
                        android:orientation="horizontal"
                        android:paddingStart="4dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="4dp"
                        android:paddingBottom="4dp">

                        <ImageView
                            android:id="@+id/menuArrowImageView"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_arrow_right" />

                        <TextView
                            android:id="@+id/menuTitleTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/profile_menu"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <View
                        android:id="@+id/menuDividerView"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:background="#EAEAF2"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/editProfileSectionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/editProfileMenuItemContainer"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_menu_profile_item"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <ImageView
                                android:id="@+id/editProfileIconImageView"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_edit_alt" />

                            <TextView
                                android:id="@+id/editProfileTextView"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:text="@string/profile_edit_profile"
                                android:textColor="@color/color_navy_blue"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/themeSectionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/themeMenuItemContainer"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_menu_profile_item"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <ImageView
                                android:id="@+id/themeIconImageView"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/day_and_night_mode" />

                            <TextView
                                android:id="@+id/themeTextView"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:text="@string/profile_theme"
                                android:textColor="@color/color_navy_blue"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/helpSectionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/helpMenuItemContainer"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_menu_profile_item"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <ImageView
                                android:id="@+id/helpIconImageView"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_help" />

                            <TextView
                                android:id="@+id/helpTextView"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:text="@string/profile_help"
                                android:textColor="@color/color_navy_blue"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/aboutSectionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/aboutMenuItemContainer"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_menu_profile_item"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <ImageView
                                android:id="@+id/aboutIconImageView"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_reset_info" />

                            <TextView
                                android:id="@+id/aboutTextView"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:text="@string/profile_about"
                                android:textColor="@color/color_navy_blue"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/logoutSectionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <LinearLayout
                            android:id="@+id/logoutMenuItemContainer"
                            android:layout_width="match_parent"
                            android:layout_height="44dp"
                            android:layout_marginBottom="12dp"
                            android:background="@drawable/bg_menu_profile_item"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackground"
                            android:gravity="center_vertical"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <ImageView
                                android:id="@+id/logoutIconImageView"
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_logout" />

                            <TextView
                                android:id="@+id/logoutTextView"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="10dp"
                                android:layout_weight="1"
                                android:text="@string/profile_logout"
                                android:textColor="@color/color_navy_blue"
                                android:textSize="15sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>