<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/favoritesRootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    tools:context=".ui.FavoritesFragment">

    <LinearLayout
        android:id="@+id/favoritesHeaderContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="20dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/favoritesTitleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/favorites_favorites"
            android:textColor="@color/color_navy_blue"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/favoritesSubtitleTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/favorites_your_saved_questions_will_appear_here"
            android:textColor="@color/color_text_hint"
            android:textSize="14sp" />

    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/favoritesEmptyStateCardView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="20dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:strokeColor="@color/color_surface"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/favoritesHeaderContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/favoritesEmptyStateContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="36dp"
            android:paddingEnd="24dp"
            android:paddingBottom="36dp">

            <ImageView
                android:id="@+id/favoritesEmptyImageView"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/ic_bookmark"
                app:tint="@color/color_orange_primary"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/favoritesEmptyTitleTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/favorites_no_favorite_questions_yet"
                android:textColor="@color/color_navy_blue"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/favoritesEmptyDescriptionTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/when_you_save_qufavorites_estions_during_a_quiz_they_will_appear_here_for_quick_review"
                android:textAlignment="center"
                android:textColor="@color/color_text_hint"
                android:textSize="14sp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/favoritesRecyclerView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:clipToPadding="false"
        android:paddingBottom="90dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/favoritesHeaderContainer"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_favorite_question" />

</androidx.constraintlayout.widget.ConstraintLayout>