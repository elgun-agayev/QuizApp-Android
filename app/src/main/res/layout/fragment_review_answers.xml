<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/reviewAnswersRootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    tools:context=".ui.ReviewAnswersFragment">

    <LinearLayout
        android:id="@+id/reviewAnswersMainContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginBottom="12dp"
        android:orientation="vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="36dp">

        <LinearLayout
            android:id="@+id/reviewAnswersTopBarContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/reviewAnswersBackImageView"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_white"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                android:clickable="true"
                android:focusable="true"
                android:contentDescription="@null"
                app:tint="@color/color_navy_blue" />

            <LinearLayout
                android:id="@+id/reviewAnswersTitleContainer"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/reviewAnswersTitleTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/review_answers_review_answers"
                    android:textColor="@color/color_navy_blue"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/reviewAnswersSubtitleTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/review_answers_check_your_correct_and_wrong_answers"
                    android:textColor="@color/color_text_hint"
                    android:textSize="13sp" />
            </LinearLayout>

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/reviewAnswersInfoCardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardBackgroundColor="@color/color_surface"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/color_lavender"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/reviewAnswersInfoContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/reviewAnswersInfoTitleTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/review_answers_answer_review"
                    android:textColor="@color/color_navy_blue"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/reviewAnswersInfoDescriptionTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/review_answers_you_can_review_all_answered_questions_here_and_save_important_ones_to_favorites"
                    android:textColor="@color/color_text_hint"
                    android:textSize="13sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/reviewAnswersRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="16dp"
            android:clipToPadding="false"
            android:paddingBottom="16dp"
            tools:listitem="@layout/item_review_answer"
            android:layout_weight="1" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/reviewAnswersEmptyStateCardView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/color_surface"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/color_lavender"
            app:strokeWidth="1dp">

            <LinearLayout
                android:id="@+id/reviewAnswersEmptyStateContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="24dp">

                <ImageView
                    android:id="@+id/reviewAnswersEmptyStateImageView"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_bookmark"
                    android:contentDescription="@null"
                    app:tint="@color/color_text_hint" />

                <TextView
                    android:id="@+id/reviewAnswersEmptyStateTitleTextView"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/review_answers_no_review_data_yet"
                    android:textColor="@color/color_navy_blue"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/reviewAnswersEmptyStateDescriptionTextView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/review_answers_finish_a_quiz_first_to_see_your_answer_review_here"
                    android:textColor="@color/color_text_hint"
                    android:textSize="14sp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>