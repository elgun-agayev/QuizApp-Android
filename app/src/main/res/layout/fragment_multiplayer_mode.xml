<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_multiplayer_mode"
    tools:context=".ui.MultiPlayerModeFragment">

    <View
        android:id="@+id/backgroundOverlayView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#33000000"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/multiplayerNestedScrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:paddingTop="36dp"
        android:paddingBottom="28dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingTop="28dp"
            android:paddingEnd="20dp"
            android:paddingBottom="28dp">

            <TextView
                android:id="@+id/multiplayerTitleTextView"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="20dp"
                android:shadowColor="#452C3E50"
                android:shadowDx="0"
                android:shadowDy="3"
                android:shadowRadius="8"
                android:text="@string/multiplayer_mode_multiplayer"
                android:textAlignment="center"
                android:textColor="@color/color_aqua_orange"
                android:textSize="34sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="8dp"
                android:alpha="0.9"
                android:text="@string/multiplayer_mode_choose_how_you_want_to_play"
                android:textColor="@color/color_white"
                android:textSize="15sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/randomPlayerSectionContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="#F7FBFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:strokeColor="#1A203A6F"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:id="@+id/randomPlayerSelectorContainer"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_white"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/randomPlayerTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/multiplayer_mode_play_with_random_player"
                                android:textColor="@color/color_navy_blue"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/multiplayer_mode_match_with_online_players_instantly"
                                android:textColor="@color/color_text_hint"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/randomPlayerToggleImageView"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:clickable="true"
                            android:contentDescription="@string/multiplayer_mode_toggle_random_match_options"
                            android:focusable="true"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="@color/color_success" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/categoryLabelTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="6dp"
                        android:text="@string/multiplayer_mode_category"
                        android:textColor="@color/color_text_hint"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/randomCategorySelectorContainer"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_white"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/randomCategoryTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_select_category"
                            android:textColor="@color/color_text_hint"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            tools:ignore="NestedWeights" />

                        <ImageView
                            android:id="@+id/randomCategoryArrowImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:clickable="true"
                            android:contentDescription="@string/multiplayer_mode_expand_category_options"
                            android:focusable="true"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="@color/color_navy_blue" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/randomCategoryChipCardView"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        app:cardBackgroundColor="@color/color_surface"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/color_purple"
                        app:strokeWidth="1dp">

                        <TextView
                            android:id="@+id/randomCategoryChipTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="16dp"
                            android:drawableStart="@drawable/ic_chip_informatics"
                            android:drawablePadding="6dp"
                            android:text="@string/multiplayer_mode_informatics"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:id="@+id/randomInformaticsOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/randomInformaticsImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_category_informatics" />

                        <TextView
                            android:id="@+id/randomInformaticsTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_informatics"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/randomMathematicsOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/randomMathematicsImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_catagory_math_pi" />

                        <TextView
                            android:id="@+id/randomMathematicsTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_mathematics"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/randomEnglishOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/randomEnglishImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_category_english" />

                        <TextView
                            android:id="@+id/randomEnglishTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_english"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/randomHistoryOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/randomHistoryImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_category_history" />

                        <TextView
                            android:id="@+id/randomHistoryTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_history"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/randomWorldviewOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/randomWorldviewImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_category_knowledge" />

                        <TextView
                            android:id="@+id/randomWorldviewTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_worldview"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/randomLogicOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/randomLogicImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_category_logic" />

                        <TextView
                            android:id="@+id/randomLogicTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_logic"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/teamLabelTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="6dp"
                        android:text="@string/multiplayer_mode_team_format"
                        android:textColor="@color/color_text_hint"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/randomTeamFormatSelectorContainer"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_white"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/randomTeamFormatTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_select_team_format"
                            android:textColor="@color/color_text_hint"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/randomTeamFormatArrowImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:clickable="true"
                            android:contentDescription="@string/multiplayer_mode_expand_team_format_options"
                            android:focusable="true"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="@color/color_navy_blue" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/randomTwoVsTwoOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/randomTwoVsTwoTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/multiplayer_mode__2v2"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/randomThreeVsThreeOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/randomThreeVsThreeTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/multiplayer_mode__3v3"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/randomFourVsFourOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/randomFourVsFourTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/multiplayer_mode__4v4"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/friendsSectionContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                app:cardBackgroundColor="#F7FBFF"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:strokeColor="#1A203A6F"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:id="@+id/friendsSelectorContainer"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:background="@drawable/bg_white"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/playWithFriendsTextView"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/multiplayer_mode_play_with_friends"
                                android:textColor="@color/color_navy_blue"
                                android:textSize="18sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/multiplayer_mode_create_a_room_or_join_by_room_id"
                                android:textColor="@color/color_text_hint"
                                android:textSize="12sp" />
                        </LinearLayout>

                        <ImageView
                            android:id="@+id/playWithFriendsToggleImageView"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:clickable="true"
                            android:contentDescription="@string/multiplayer_mode_toggle_friends_match_options"
                            android:focusable="true"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="@color/color_success" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/withfriendscategoryLabelTextView"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginTop="18dp"
                        android:layout_marginBottom="6dp"
                        android:text="@string/multiplayer_mode_category"
                        android:textColor="@color/color_text_hint"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/friendsCategorySelectorContainer"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/bg_white"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/friendsCategoryTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_select_category"
                            android:textColor="@color/color_text_hint"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/friendsCategoryArrowImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:clickable="true"
                            android:contentDescription="@string/multiplayer_mode_expand_friends_category_options"
                            android:focusable="true"
                            android:src="@drawable/ic_arrow_down"
                            app:tint="@color/color_navy_blue" />
                    </LinearLayout>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/friendsCategoryChipCardView"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:layout_marginTop="8dp"
                        android:visibility="gone"
                        app:cardBackgroundColor="@color/color_surface"
                        app:cardCornerRadius="18dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/color_purple"
                        app:strokeWidth="1dp">

                        <TextView
                            android:id="@+id/friendsCategoryChipTextView"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"
                            android:gravity="center_vertical"
                            android:paddingStart="14dp"
                            android:paddingEnd="16dp"
                            android:drawableStart="@drawable/ic_chip_informatics"
                            android:drawablePadding="6dp"
                            android:text="@string/multiplayer_mode_informatics"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="14sp"
                            android:textStyle="bold" />
                    </com.google.android.material.card.MaterialCardView>

                    <LinearLayout
                        android:id="@+id/friendsInformaticsOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/friendsInformaticsImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_category_informatics" />

                        <TextView
                            android:id="@+id/friendsInformaticsTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_informatics"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/friendsMathematicsOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/friendsMathematicsImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_catagory_math_pi" />

                        <TextView
                            android:id="@+id/friendsMathematicsTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_mathematics"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/friendsEnglishOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/friendsEnglishImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_category_english" />

                        <TextView
                            android:id="@+id/friendsEnglishTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_english"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/friendsHistoryOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/friendsHistoryImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_category_history" />

                        <TextView
                            android:id="@+id/friendsHistoryTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_history"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/friendsWorldviewOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/friendsWorldviewImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_category_knowledge" />

                        <TextView
                            android:id="@+id/friendsWorldviewTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_worldview"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/friendsLogicOptionContainer"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_button_ct"
                        android:clickable="true"
                        android:focusable="true"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/friendsLogicImageView"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_category_logic" />

                        <TextView
                            android:id="@+id/friendsLogicTextView"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:text="@string/multiplayer_mode_logic"
                            android:textColor="@color/color_navy_blue"
                            android:textSize="15sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/friendsRoomIdInputContainer"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_white"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp"
                        android:visibility="gone">

                        <EditText
                            android:id="@+id/roomIdFriendsEditText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:alpha="0.7"
                            android:background="@android:color/transparent"
                            android:clickable="false"
                            android:enabled="false"
                            android:focusable="false"
                            android:hint="@string/multiplayer_mode_enter_room_id"
                            android:textColor="@color/color_navy_blue"
                            android:textColorHint="@color/color_text_hint"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:inputType="textCapSentences"
                            android:maxLines="1"
                            android:imeOptions="actionDone"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/searchPlayerMaterialCardView"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="22dp"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone"
                app:cardBackgroundColor="#E6A87E"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp"
                app:strokeColor="@color/color_navy_blue"
                app:strokeWidth="2dp">

                <TextView
                    android:id="@+id/searchPlayerButtonTextView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:enabled="false"
                    android:gravity="center"
                    android:text="@string/multiplayer_mode_search_player"
                    android:textColor="@color/color_navy_blue"
                    android:textSize="17sp"
                    android:textStyle="bold" />
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/friendsActionButtonsRow"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="14dp"
                android:orientation="horizontal"
                android:visibility="gone">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/createRoomMaterialCardView"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#E6A87E"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:strokeColor="@color/color_navy_blue"
                    app:strokeWidth="2dp">

                    <TextView
                        android:id="@+id/createRoomTextView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:enabled="false"
                        android:gravity="center"
                        android:text="@string/multiplayer_mode_create_room"
                        android:textColor="@color/color_navy_blue"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>

                <Space
                    android:layout_width="12dp"
                    android:layout_height="match_parent" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/joinByIdRoomMaterialCardView"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardBackgroundColor="#E6A87E"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="6dp"
                    app:strokeColor="@color/color_navy_blue"
                    app:strokeWidth="2dp">

                    <TextView
                        android:id="@+id/joinByIdRoomTextView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:enabled="false"
                        android:gravity="center"
                        android:text="@string/multiplayer_mode_join_by_id"
                        android:textColor="@color/color_navy_blue"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>